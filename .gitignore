# Build artefacts.
# - platform.duckdb is rebuilt on backend boot from MySQL, so it's
#   gitignored (also avoids stale binary diffs).
# - model.pkl + the embedding parquets + the regulation source docs
#   are baked into the deployed image (the ECS Fargate filesystem is
#   ephemeral, so they need to ship). Total ~80 MB.
data/platform.duckdb
data/*.duckdb.wal

# Eval run outputs — keep the folder, ignore the timestamped JSON dumps.
evals/results/*
!evals/results/.gitkeep

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store

# Terraform local state + plugin cache.
# State files contain secrets (the random RDS password). Never commit.
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.*
infra/*.tfplan
infra/.terraform.tfstate.lock.info
