!.env.example

# Build artefacts.
# - platform.duckdb is rebuilt on backend boot from MySQL.
# - model.pkl + embedding parquets live in S3 (provisioned by
#   infra/s3.tf). Backend downloads them on container boot.
# - The regulation source docs (data/regulations/docs/*.md) ARE
#   committed -- they're the input to build_regulation_corpus.
data/*
!data/.gitkeep
!data/regulations/
data/regulations/*
!data/regulations/docs/
!data/regulations/docs/**

# Eval run outputs — keep the folder, ignore the timestamped JSON dumps.
evals/results/*
!evals/results/.gitkeep

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store

# Terraform local state + plugin cache.
# State files contain secrets (the random RDS password). Never commit.
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.*
infra/*.tfplan
infra/.terraform.tfstate.lock.info
