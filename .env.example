# LLM provider toggle. "azure" uses Azure OpenAI (default for dev).
# "bedrock" uses AWS Bedrock (Claude on AWS) -- requires Bedrock model
# access enabled in the AWS console + boto3 credentials available
# (~/.aws/credentials or IAM role / instance profile).
LLM_PROVIDER=azure

# Azure OpenAI (re-use the same credentials as mcnab-data-app for dev)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_MODEL=gpt-4o
AZURE_OPENAI_EMBED_MODEL=text-embedding-3-small

# AWS Bedrock (only used when LLM_PROVIDER=bedrock). Embeddings stay on
# Azure regardless -- the RAG parquet was built with text-embedding-3-small.
# BEDROCK_CHAT_MODEL is a cross-region inference profile (au./us./eu./jp.
# /global. prefix). Default `au.` routes through ap-southeast-2 (Sydney).
AWS_REGION=ap-southeast-2
BEDROCK_CHAT_MODEL=au.anthropic.claude-sonnet-4-6

# Tavily web search (free tier: 1000/month)
TAVILY_API_KEY=

# Local paths (defaults match the repo layout — usually leave alone)
DATA_DIR=./data
MODEL_PATH=./data/model.pkl
DUCKDB_PATH=./data/platform.duckdb

# MySQL (OLTP). Defaults match docker-compose.yml — `docker compose up -d mysql`.
# In AWS (Phase 2) these come from Secrets Manager via the ECS task definition.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_DATABASE=reapit_demo

# CORS
CORS_ORIGINS=http://localhost:5173
