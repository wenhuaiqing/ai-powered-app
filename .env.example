# AWS Bedrock provides both chat (Claude Sonnet 4.6) and embeddings
# (Titan v2). Local dev needs AWS creds on PATH (`aws configure` or
# env vars) + Bedrock model access enabled in the target region.
# BEDROCK_CHAT_MODEL uses a cross-region inference profile prefix:
#   au. -> ap-southeast-2 (Sydney)
#   us. -> us-east-1 / us-west-2
#   eu. -> eu-*
AWS_REGION=ap-southeast-2
BEDROCK_CHAT_MODEL=au.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# S3 bucket holding model.pkl + RAG parquets (cloud deploy reads here on
# boot). Local dev can leave empty -- scripts read/write data/ on disk.
S3_ARTEFACT_BUCKET=

# Tavily web search (free tier: 1000/month)
TAVILY_API_KEY=

# Local paths (defaults match the repo layout — usually leave alone)
DATA_DIR=./data
MODEL_PATH=./data/model.pkl
DUCKDB_PATH=./data/platform.duckdb

# MySQL (OLTP). Defaults match docker-compose.yml — `docker compose up -d mysql`.
# In AWS (Phase 2) these come from Secrets Manager via the ECS task definition.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_DATABASE=reapit_demo

# CORS
CORS_ORIGINS=http://localhost:5173
