# Repo-root .dockerignore. Applies to all `docker build` invocations
# from this directory (which is the context for both the backend and
# frontend Dockerfiles).

# VCS
.git
.gitignore
.gitattributes

# Local secrets + env
.env
.env.local
.env.*.local

# Python build / cache
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
backend/.venv/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Don't ship the ephemeral DuckDB into the image; the backend rebuilds
# it from MySQL on boot. Everything else under data/ (model.pkl, the
# embedding parquets, regulation source docs) DOES ship.
data/platform.duckdb
data/*.duckdb.wal

# Docs / IDE
.vscode/
.idea/
*.swp
.DS_Store

# Claude / project tools
.claude/
docs/screenshots/

# Test outputs
evals/results/
htmlcov/
.coverage

# Terraform state
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/.terraform.lock.hcl
